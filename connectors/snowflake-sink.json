{
  "name": "snowflake-sink-connector",
  "config": {
    "connector.class": "com.snowflake.kafka.connector.SnowflakeSinkConnector",
    "tasks.max": "2",
    "topics": "cdc.public.iot_events",
    "snowflake.url.name": "<SNOWFLAKE_ACCOUNT_URL>.snowflakecomputing.com",
    "snowflake.user.name": "KAFKA_CONNECTOR_USER",
    "snowflake.private.key": "${file:/secrets/snowflake:private_key}",
    "snowflake.database.name": "HACKATHON_IOT",
    "snowflake.schema.name": "RAW",
    "snowflake.role.name": "IOT_PIPELINE_ROLE",
    "snowflake.topic2table.map": "cdc.public.iot_events:IOT_EVENTS",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "com.snowflake.kafka.connector.records.SnowflakeJsonConverter",
    "buffer.count.records": "10000",
    "buffer.flush.time": "10",
    "buffer.size.bytes": "5000000"
  }
}
