       "PostgresSecurityGroupEA9E32B6",
       "GroupId"
      ]
     }
    ],
    "SubnetId": {
     "Fn::ImportValue": "IoT-VpcStack:ExportsOutputRefIoTVpcPrivateSubnet1Subnet85772440AD77B3A3"
    },
    "Tags": [
     {
      "Key": "Name",
      "Value": "IoT-Ec2DbStack/PostgresEc2"
     }
    ],
    "UserData": {
     "Fn::Base64": {
      "Fn::Join": [
       "",
       [
        "#!/bin/bash\n#!/bin/bash\ndnf update -y\ndnf install -y postgresql15-server postgresql15 jq\npostgresql-setup --initdb\nsed -i \"s/#wal_level = replica/wal_level = logical/\" /var/lib/pgsql/data/postgresql.conf\nsed -i \"s/#max_replication_slots = 10/max_replication_slots = 4/\" /var/lib/pgsql/data/postgresql.conf\nsed -i \"s/#max_wal_senders = 10/max_wal_senders = 4/\" /var/lib/pgsql/data/postgresql.conf\necho \"listen_addresses = '*'\" >> /var/lib/pgsql/data/postgresql.conf\necho \"host all all ",
        {
         "Fn::ImportValue": "IoT-VpcStack:ExportsOutputFnGetAttIoTVpcD571E817CidrBlock4C194008"
        },
        " md5\" >> /var/lib/pgsql/data/pg_hba.conf\necho \"host replication all ",
        {
         "Fn::ImportValue": "IoT-VpcStack:ExportsOutputFnGetAttIoTVpcD571E817CidrBlock4C194008"
        },
        " md5\" >> /var/lib/pgsql/data/pg_hba.conf\nsystemctl start postgresql\nsystemctl enable postgresql\nSECRET_VAL=$(aws secretsmanager get-secret-value --secret-id ",
        {
         "Ref": "PostgreSqlCredentialsBFDBA330"
        },
        " --region ",
        {
         "Ref": "AWS::Region"
        },
        " --query SecretString --output text)\nDB_PASS=$(echo $SECRET_VAL | jq -r .password)\nsudo -u postgres psql -c \"ALTER USER postgres WITH PASSWORD '$DB_PASS';\"\nsudo -u postgres psql -c \"CREATE DATABASE iot_db;\"\nsudo -u postgres psql -d iot_db -c \"CREATE USER replication_user WITH REPLICATION PASSWORD '$DB_PASS';\"\nsudo -u postgres psql -d iot_db -c \"CREATE TABLE IF NOT EXISTS public.iot_events (  id SERIAL PRIMARY KEY,  device_id VARCHAR(50) NOT NULL,  latitude DOUBLE PRECISION NOT NULL,  longitude DOUBLE PRECISION NOT NULL,  aqi INT,  temperature NUMERIC(5,2),  timestamp TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP);\"\nsudo -u postgres psql -d iot_db -c \"GRANT ALL PRIVILEGES ON TABLE public.iot_events TO replication_user;\"\nsudo -u postgres psql -d iot_db -c \"GRANT USAGE, SELECT ON SEQUENCE iot_events_id_seq TO replication_user;\""
       ]
      ]
     }
    }
